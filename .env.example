# Example configuration for CAP-CDTS
# Copy to .env and edit.

CAP_CDTS_BIND_ADDR=0.0.0.0:8080
CAP_CDTS_STORE_PATH=data/store.json

# REQUIRED to enable Update endpoints/UI
CAP_CDTS_ADMIN_TOKEN=CHANGE_ME

CAP_CDTS_UPDATE_ENABLED=1
CAP_CDTS_UPDATE_AUTO_RESTART=1
CAP_CDTS_REPO_DIR=.
CAP_CDTS_UPDATE_NEW_BIN=bin/cap-cdts-backend.new
#CAP_CDTS_UPDATE_LIVE_BIN=bin/cap-cdts-backend
CAP_CDTS_UPDATE_LOG_LINES=400
